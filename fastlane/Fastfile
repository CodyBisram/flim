default_platform(:ios)

APP_IDENTIFIER = "com.flim.app"
XCODEPROJ      = "Flim.xcodeproj"
SCHEME         = "Flim"

platform :ios do
  before_all do
    # On CI this creates an isolated temporary keychain so match can install the
    # signing identity without prompting. It's a no-op on local machines.
    setup_ci
  end

  # ---------------------------------------------------------------------------
  # Helpers
  # ---------------------------------------------------------------------------

  # The project is generated from project.yml, so regenerate it before building
  # to guarantee the .xcodeproj matches the source of truth.
  def regenerate_project
    sh("command -v xcodegen >/dev/null 2>&1 || brew install xcodegen")
    Dir.chdir("..") { sh("xcodegen generate") }
  end

  def asc_api_key
    app_store_connect_api_key(
      key_id:                  ENV.fetch("ASC_KEY_ID"),
      issuer_id:               ENV.fetch("ASC_ISSUER_ID"),
      key_content:             ENV.fetch("ASC_KEY_P8"),
      is_key_content_base64:   true,
      in_house:                false
    )
  end

  # ---------------------------------------------------------------------------
  # Lanes
  # ---------------------------------------------------------------------------

  desc "One-time, run locally: create the App Store signing cert + profile and push them to the match repo"
  lane :certificates do
    match(
      type:           "appstore",
      app_identifier: APP_IDENTIFIER,
      api_key:        asc_api_key,
      readonly:       false
    )
  end

  desc "Build a signed Release archive and upload it to TestFlight"
  lane :beta do
    regenerate_project
    api_key = asc_api_key

    # Pull the shared distribution cert + profile (read-only on CI).
    match(
      type:           "appstore",
      app_identifier: APP_IDENTIFIER,
      api_key:        api_key,
      readonly:       is_ci
    )

    # Next build number = highest already on TestFlight + 1 (App Store Connect
    # rejects duplicate build numbers). Falls back to 0 for a brand-new app.
    build_number = latest_testflight_build_number(
      app_identifier:       APP_IDENTIFIER,
      api_key:              api_key,
      initial_build_number: 0
    ) + 1
    UI.message("Building FLIM build ##{build_number}")

    profile_name = ENV["sigh_#{APP_IDENTIFIER}_appstore_profile-name"] ||
                   "match AppStore #{APP_IDENTIFIER}"

    build_app(
      project:        XCODEPROJ,
      scheme:         SCHEME,
      configuration:  "Release",
      export_method:  "app-store",
      output_directory: "build",
      output_name:    "Flim.ipa",
      xcargs: [
        "CURRENT_PROJECT_VERSION=#{build_number}",
        "DEVELOPMENT_TEAM=#{ENV.fetch('APPLE_TEAM_ID')}",
        "CODE_SIGN_STYLE=Manual",
        "CODE_SIGN_IDENTITY=Apple\\ Distribution",
        "PROVISIONING_PROFILE_SPECIFIER=#{profile_name.gsub(' ', '\\ ')}",
        "-allowProvisioningUpdates"
      ].join(" "),
      export_options: {
        method:        "app-store",
        signingStyle:  "manual",
        teamID:        ENV.fetch("APPLE_TEAM_ID"),
        provisioningProfiles: { APP_IDENTIFIER => profile_name }
      }
    )

    upload_to_testflight(
      api_key:                          api_key,
      app_identifier:                   APP_IDENTIFIER,
      skip_waiting_for_build_processing: true,  # don't burn CI minutes waiting on Apple
      distribute_external:              false
    )
  end
end
